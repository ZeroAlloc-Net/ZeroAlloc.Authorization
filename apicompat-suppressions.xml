<?xml version="1.0" encoding="utf-8"?>
<!--
  ZA.Authorization v2.0.0 — intentional API breaks as part of the major version bump.

  Five breakages are suppressed:
  - Two type removals: the v1 [AuthorizationPolicy] and [Authorize] attributes,
    renamed to [Policy] and [RequirePolicy] respectively. The rename eliminates
    the name collision with Microsoft.AspNetCore.Authorization.AuthorizeAttribute
    and provides a clean grammatical pair (declare-side / require-side).
  - Three method removals: the four-method IAuthorizationPolicy contract collapses
    to a single async EvaluateAsync (the surviving method). Sync-only policies
    wrap their result in new ValueTask<...>(result) — allocation-free on the stack.

  See docs/plans/2026-05-19-policy-registry-generator-design.md for the design
  decisions that led to these breaks.
-->
<Suppressions>
  <Suppression>
    <DiagnosticId>CP0001</DiagnosticId>
    <Target>T:ZeroAlloc.Authorization.AuthorizationPolicyAttribute</Target>
    <Justification>Renamed to [Policy] in v2.0.0 — intentional breaking change for the major version bump.</Justification>
  </Suppression>
  <Suppression>
    <DiagnosticId>CP0001</DiagnosticId>
    <Target>T:ZeroAlloc.Authorization.AuthorizeAttribute</Target>
    <Justification>Renamed to [RequirePolicy] in v2.0.0 to eliminate name collision with Microsoft.AspNetCore.Authorization.AuthorizeAttribute. Intentional breaking change for the major version bump.</Justification>
  </Suppression>
  <Suppression>
    <DiagnosticId>CP0002</DiagnosticId>
    <Target>M:ZeroAlloc.Authorization.IAuthorizationPolicy.IsAuthorized(ZeroAlloc.Authorization.ISecurityContext)</Target>
    <Justification>IAuthorizationPolicy reduced to single EvaluateAsync method in v2.0.0. Sync-only policies wrap their result in new ValueTask&lt;...&gt;(result) — allocation-free. Intentional breaking change for the major version bump.</Justification>
  </Suppression>
  <Suppression>
    <DiagnosticId>CP0002</DiagnosticId>
    <Target>M:ZeroAlloc.Authorization.IAuthorizationPolicy.IsAuthorizedAsync(ZeroAlloc.Authorization.ISecurityContext,System.Threading.CancellationToken)</Target>
    <Justification>IAuthorizationPolicy reduced to single EvaluateAsync method in v2.0.0. Intentional breaking change for the major version bump.</Justification>
  </Suppression>
  <Suppression>
    <DiagnosticId>CP0002</DiagnosticId>
    <Target>M:ZeroAlloc.Authorization.IAuthorizationPolicy.Evaluate(ZeroAlloc.Authorization.ISecurityContext)</Target>
    <Justification>IAuthorizationPolicy reduced to single EvaluateAsync method in v2.0.0. Sync-callers migrate to EvaluateAsync and ValueTask wrapping. Intentional breaking change for the major version bump.</Justification>
  </Suppression>
</Suppressions>
