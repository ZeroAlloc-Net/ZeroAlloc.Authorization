<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <IsPackable>false</IsPackable>
    <OptimizationPreference>Size</OptimizationPreference>
    <RootNamespace>ZeroAlloc.Authorization.AotSmoke</RootNamespace>
    <NoWarn>$(NoWarn);MA0002;MA0004;MA0047;MA0048</NoWarn>

    <WarningsAsErrors>$(WarningsAsErrors);IL2026;IL2067;IL2075;IL2091;IL3050;IL3051</WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\ZeroAlloc.Authorization\ZeroAlloc.Authorization.csproj"
                      SetTargetFramework="TargetFramework=net10.0" />
  </ItemGroup>
</Project>
